# Azure Account (for deploy.ps1)
AZURE_TENANT_ID=your-tenant-id
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=vibekids
AZURE_LOCATION=eastus2
AZURE_APP_NAME=vibekid
AZURE_ENV_NAME=vibekid-env

# Azure OpenAI Configuration (v1 endpoint)
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/openai/v1/

# Model deployments
# Chat: GPT-5.4 (latest reasoning model, 2026-03-05)
AZURE_OPENAI_DEPLOYMENT=gpt-5.4

# TTS: gpt-4o-mini-tts (supports voice style instructions)
AZURE_OPENAI_TTS_DEPLOYMENT=gpt-4o-mini-tts

# STT: gpt-4o-mini-transcribe (improved accuracy over whisper)
AZURE_OPENAI_STT_DEPLOYMENT=gpt-4o-mini-transcribe
